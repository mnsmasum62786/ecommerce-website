# ---------------------------------------------------------------------------
# Verdant Organic Store — environment variables
# Copy to .env and fill in. NEVER commit your real .env file.
# ---------------------------------------------------------------------------

# --- Database (Vercel Postgres / Neon) ---
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- NextAuth ---
# App URL. In Vercel this is set automatically, but define it for local dev.
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# --- Seed admin credentials (used by `npm run seed`) ---
ADMIN_EMAIL="admin@verdantmarket.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Store Admin"

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Webhook signing secret from the Stripe dashboard / CLI.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Vercel Blob (image uploads) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# --- Resend (transactional email) ---
RESEND_API_KEY="re_xxx"
# Verified sender address.
EMAIL_FROM="Verdant Market <orders@verdantmarket.com>"

# --- App ---
# Public base URL used in emails, sitemap, and webhook callbacks.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
